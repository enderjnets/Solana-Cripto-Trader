# Solana Jupiter Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# Network
SOLANA_RPC_DEVNET=https://api.devnet.solana.com
SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com
SOLANA_RPC_TESTNET=https://api.testnet.solana.com

# Wallet (use ONLY addresses, not private keys!)
HOT_WALLET_ADDRESS=
COLD_WALLET_ADDRESS=

# Jupiter API (optional - uses public API by default)
JUPITER_API_KEY=

# MiniMax M2.7 — LLM fallback principal
# Obtener API key en: https://api.minimax.io
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO

# ── Servicios opcionales (solo si tienes tu propio servidor) ─────────────────
# GPT-5.4 via proxy OpenClaw — si no responde, usa MiniMax automáticamente
# GPT5_URL=http://127.0.0.1:18793/v1/chat/completions

# Paperclip (tablero de control de agentes) — bot funciona sin él
# PAPERCLIP_API=http://100.88.47.99:3100
# PAPERCLIP_API_KEY=pcp_...

# OpenClaw Webhooks — notificaciones Telegram via OpenClaw (opcional)
# OPENCLAW_WEBHOOK_URL=http://127.0.0.1:18789/plugins/webhooks/solana-alerts
# OPENCLAW_WEBHOOK_SECRET=...

# Workspace path — solo si no usas ~/.openclaw/workspace/Solana-Cripto-Trader
# SOLANA_WORKSPACE=/home/tu-usuario/.openclaw/workspace

# Qwen 2.5 14B local via Ollama -- 4to fallback LLM (solo si tienes Ollama)
# QWEN_URL=http://localhost:11434/api/chat
# QWEN_MODEL=qwen2.5:14b
# LLM Efficiency tuning (v2.6.0) — ajustar sensibilidad del cache
# WILD_LLM_PRICE_THRESHOLD=0.3   # % cambio minimo en 5min para forzar llamada LLM (default: 0.3%)
# WILD_LLM_CACHE_SEC=600         # max segundos entre llamadas LLM en WILD mode (default: 10min)
# STRATEGY_CACHE_SEC=900         # max segundos entre regeneracion de AI Strategy (default: 15min)

# ════════════════════════════════════════════════════════════════════
# ── v2.10.0-live — CONFIG PARA TRADING REAL (opt-in) ────────────────
# ════════════════════════════════════════════════════════════════════
# Todas las variables debajo son SOLO PARA EL LIVE CLONE.
# Mientras LIVE_TRADING_ENABLED=false, el bot corre idéntico al paper.
# NO completes estas variables hasta estar listo para mainnet real.

# ── Master switch ──────────────────────────────────────────────────
# Por defecto false. Cuando pongas true, safety.validate_startup()
# exigirá que HOT_WALLET_PRIVATE_KEY + SOLANA_RPC_URL +
# MAX_DAILY_LOSS_USD + TRADE_WHITELIST + MAX_SLIPPAGE_BPS estén todos
# configurados; si falta cualquiera, el orchestrator NO arranca.
LIVE_TRADING_ENABLED=false

# ── Wallet Solana (Fase 1 del Sprint 2) ────────────────────────────
# Generar wallet: `python3 tools/solana_wallet.py --generate`
# El tool guarda privkey en ~/.config/solana-jupiter-bot/wallet.json
# IMPORTANTE: mover a formato encriptado antes de producción real.
# NUNCA commitear private keys al repo.
HOT_WALLET_ADDRESS=
# HOT_WALLET_PRIVATE_KEY=   # base64-encoded encrypted JSON (Fase 1)
# WALLET_PASSPHRASE=                   # passphrase para decrypt (mejor via env no en .env)

# ── RPC Solana (Fase 1) ────────────────────────────────────────────
# Helius free tier (500k req/mes, incluye priority fees API)
# Registrate en https://helius.dev → "Create Key" → Copia la URL completa
# Ejemplo: https://mainnet.helius-rpc.com/?api-key=xxxxxxxx
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_RPC_URL=

# ── Safety limits para trading real (empezar CONSERVADORES) ────────
# Todos estos se validan en safety.validate_startup() cuando
# LIVE_TRADING_ENABLED=true. El bot NO arranca si falta alguno.
MAX_DAILY_LOSS_USD=5             # pausa al superar esta pérdida diaria
# v2.12.17: per-symbol slippage override. Bridged/thin-liquidity tokens
# (e.g. ETH Wormhole) necesitan más tolerancia que SOL/JUP nativo.
# Format: SLIPPAGE_BPS_<SYMBOL>=<bps>. Falls back to MAX_SLIPPAGE_BPS.
SLIPPAGE_BPS_ETH=800
MAX_SLIPPAGE_BPS=100             # 1% max slippage tolerable (bps = basis points)
TRADE_WHITELIST=SOL,JUP,ETH     # v2.12.7: expandido a 3 majors (mints Wormhole validados)
LIVE_MAX_POSITION_USD=20         # tamaño máximo por posición (override de compound sizing)
LIVE_MAX_POSITIONS=1             # un solo trade a la vez en los primeros días

# ── Jupiter Swap API (Fase 2) ──────────────────────────────────────
# API pública, no requiere key. Se usa para get_quote + prepare_swap.
# Default: https://quote-api.jup.ag/v6
JUPITER_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote
JUPITER_SWAP_URL=https://lite-api.jup.ag/swap/v1/swap

# ── Watchdog externo (Fase 5) ──────────────────────────────────────
# Heartbeat timeout (segundos) antes de que emergency_close.py dispare.
# Default 300s (5min). NO bajar de 120s (false positives en ciclos lentos).
HEARTBEAT_TIMEOUT_SEC=300
HEARTBEAT_FILE=/tmp/solana_live_heartbeat

# ── v2.11.0-live: SOL auto-replenish (fuel top-up) ─────────────────
# When on-chain SOL < SOL_MIN_BALANCE, swap USDC→SOL to stay fueled.
# Default: off (dormant); enable after rollout validation.
SOL_AUTO_TOPUP_ENABLED=false
SOL_MIN_BALANCE=0.01
SOL_TOPUP_AMOUNT_USD=1.0
SOL_TOPUP_MAX_DAILY_USD=3.0
SOL_TOPUP_MIN_USDC_RESERVE=2.0

# ── v2.12.0-live: Drift Protocol perps (reemplaza spot Jupiter para trading) ─
# Ejecuta longs+shorts en SOL-PERP con leverage 1-2x cuando DRIFT_ENABLED=true.
# Jupiter queda solo para sol_topup. Requiere subaccount inicializado:
#   python3 tools/drift_setup.py --env mainnet --deposit 3.0
DRIFT_ENABLED=false
DRIFT_ENV=mainnet          # devnet para smoke tests, mainnet para real
DRIFT_RPC_URL=             # empty = usa default público, mejor Helius
DRIFT_WALLET_PATH=         # empty = ~/.config/solana-jupiter-bot/wallet.json
DRIFT_MARKET_WHITELIST=SOL
DRIFT_MAX_LEVERAGE=2        # hard cap
DRIFT_DEFAULT_LEVERAGE=1    # initial leverage, sube tras validación
DRIFT_MAX_COLLATERAL_USD=3  # cap total de USDC deposited en Drift vault
DRIFT_MIN_USDC_RESERVE=5    # USDC mínimo que queda en hot wallet (buffer)
DRIFT_FUNDING_WARN_PCT=0.02 # alerta si funding anualizado > 2%

# ── v2.12.3-live: Wild Mode feature flag (default off) ───────────────
# Martingale hedge engine. Requires opt-in. Caused false daily_target_hit events
# in early live trades — keep false unless you know what you are doing.
WILD_MODE_ENABLED=false

# v2.12.5-live: optional reactivacion de GPT-5.4 (si reviven port 18793)
LLM_ALLOW_GPT5=false
