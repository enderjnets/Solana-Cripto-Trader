# ════════════════════════════════════════════════════════════════════
# Solana-Cripto-Trader-Live — config para branch `live`
# ════════════════════════════════════════════════════════════════════
# Paper sigue corriendo en ~/.openclaw/workspace/Solana-Cripto-Trader/
# (puerto 8081, lock /tmp/solana_jupiter_orchestrator.lock)
#
# Este clone corre en puerto 8082 con locks propios.

# ── Isolacion de procesos (paralelo con paper) ──────────────────────
ORCH_LOCK_FILE=/tmp/solana_live_orchestrator.lock
WATCHDOG_PREFIX=solana_live
ORCH_PGREP_PATTERN=Solana-Cripto-Trader-Live/agents/orchestrator

# ── Dashboard ──────────────────────────────────────────────────────
# Lanzar: python3 dashboard/app.py 8082

# ── Telegram (mismo bot por ahora — agregar prefijo [LIVE] en codigo) ──
TELEGRAM_BOT_TOKEN=8264195169:AAG94XS7lPHh_L7DBvTNVKSR_4geB_WEju0
TELEGRAM_CHAT_ID=771213858

# ── Paperclip SOLAAA ────────────────────────────────────────────────
# v2.12.18: switched from SOLAA agent key to board key (SOLAAA access)
PAPERCLIP_API_KEY=pcp_board_68ed2bc4520167360cb1ae178b2b3285692f536e08aa7300

# ════════════════════════════════════════════════════════════════════
# ── v2.10.0-live — TRADING REAL (opt-in) ───────────────────────────
# ════════════════════════════════════════════════════════════════════

# Master switch — solo cuando TODO lo de abajo esté configurado
LIVE_TRADING_ENABLED=true

# ── Wallet Solana (Fase 1 Sprint 2) ────────────────────────────────
# Generar: `python3 tools/solana_wallet.py --generate`
# Guarda privkey en ~/.config/solana-jupiter-bot/wallet.json
HOT_WALLET_ADDRESS=EEmtkySNz1SLNZBMBu6EsuqkEhttEKjejsEXdEFT2fMH
# HOT_WALLET_PRIVATE_KEY=
# WALLET_PASSPHRASE=

# ── RPC Solana — Helius Free Tier (Fase 1) ─────────────────────────
# Signup: https://helius.dev (free, 500k req/mes, incluye priority fees API)
# Ejemplo: https://mainnet.helius-rpc.com/?api-key=XXXXXXXX
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Safety limits para trading real ────────────────────────────────
MAX_DAILY_LOSS_USD=5
# v2.12.17: per-symbol slippage override. ETH Wormhole tiene thin liquidity.
SLIPPAGE_BPS_ETH=800
MAX_SLIPPAGE_BPS=100
TRADE_WHITELIST=SOL,JUP,ETH,BTC
LIVE_MAX_POSITION_USD=10
LIVE_MAX_POSITIONS=3

# ── Jupiter Swap API (Fase 2) ──────────────────────────────────────
JUPITER_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote
JUPITER_SWAP_URL=https://lite-api.jup.ag/swap/v1/swap

# ── Watchdog externo (Fase 5) ──────────────────────────────────────
HEARTBEAT_TIMEOUT_SEC=300
HEARTBEAT_FILE=/tmp/solana_live_heartbeat

# ── v2.11.0-live: SOL auto-replenish (fuel top-up) ─────────────────
# Swap USDC → SOL cuando SOL_balance < SOL_MIN_BALANCE (default: off)
SOL_AUTO_TOPUP_ENABLED=false
SOL_MIN_BALANCE=0.01
SOL_TOPUP_AMOUNT_USD=1.0
SOL_TOPUP_MAX_DAILY_USD=3.0
SOL_TOPUP_MIN_USDC_RESERVE=2.0

# ── v2.12.0-live: Drift Protocol perps ─────────────────────────────
# Master flag — stays false hasta devnet smoke + mainnet collateral depositado
DRIFT_ENABLED=false
DRIFT_ENV=mainnet
DRIFT_RPC_URL=https://api.mainnet-beta.solana.com
DRIFT_WALLET_PATH=/home/enderj/.config/solana-jupiter-bot/wallet.json
DRIFT_MARKET_WHITELIST=SOL
DRIFT_MAX_LEVERAGE=2
DRIFT_DEFAULT_LEVERAGE=1
DRIFT_MAX_COLLATERAL_USD=3
DRIFT_MIN_USDC_RESERVE=5
DRIFT_FUNDING_WARN_PCT=0.02
WILD_MODE_ENABLED=false

# v2.12.22: Telegram signals (Phase 2 prep, disabled por defecto)
TELEGRAM_ENABLED=false
TELEGRAM_SIGNALS_BOT_TOKEN=
TELEGRAM_SIGNALS_CHANNEL=

# ── Jupiter Perpetuals (v2.13.0-live) ─────────────────────────────
JUP_PERP_ENABLED=true
JUP_PERP_DEFAULT_LEVERAGE=2.0
JUP_PERP_MAX_LEVERAGE=3.0
JUP_PERP_MARKET_WHITELIST=SOL,BTC,ETH,JUP
JUP_PERP_SLIPPAGE_BPS=200
LLM_CLOSE_CONFIDENCE_THRESHOLD=0.70
